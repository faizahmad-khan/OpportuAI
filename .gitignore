# =========================
# ROOT & OS & IDE
# =========================
.DS_Store
.AppleDouble
.LSOverride
.vscode/
.idea/
*.swp
*.swo
/venv

# =========================
# ENVIRONMENT VARIABLES
# =========================
# Strict Rule 9: .env never pushed to GitHub (.env.example will still be tracked)
.env
.env.*
!.env.example
*.local

# =========================
# FRONTEND (Next.js & Node)
# =========================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/sdks
!frontend/.yarn/versions
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/coverage/
frontend/.tsbuildinfo

# =========================
# BACKEND (Python & FastAPI)
# =========================
# Strict Rule 9: venv/ never pushed to GitHub
backend/venv/
backend/env/
backend/.venv/
backend/Scripts/
backend/bin/

# Byte-compiled / optimized / DLL files
backend/__pycache__/
*.py[cod]
*$py.class


# Testing and Profiling
backend/.pytest_cache/
backend/htmlcov/
backend/.tox/
backend/.coverage
backend/coverage.xml

# Celery & Redis Logs
backend/celerybeat-schedule
backend/celerybeat.pid

# Fallback Data and Local DBs (Just in case, though using PostgreSQL)
*.sqlite3